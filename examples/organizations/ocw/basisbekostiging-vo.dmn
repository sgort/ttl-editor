<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
             xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
             xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
             xmlns:di="http://www.omg.org/spec/DMN/20180521/DI/"
             xmlns:modeler="http://camunda.org/schema/modeler/1.0"
             xmlns:camunda="http://camunda.org/schema/1.0/dmn"
             id="BasisbekostigingVOVestigingBepaling"
             name="Basisbekostiging VO – Vestiging vast bedrag bepaling"
             namespace="http://camunda.org/schema/1.0/dmn"
             exporter="Camunda Modeler"
             exporterVersion="5.38.1"
             modeler:executionPlatform="Camunda Platform"
             modeler:executionPlatformVersion="7.23.0">

  <!--
    DRD overview
    ============
    Source      : Regeling bekostiging vo-scholen en samenwerkingsverbanden vo
    Organisation: Ministerie van OCW / DUO uitvoering
    Period      : Kalenderjaar 2025 (2025-01-01 – 2026-01-01)
    Primary key : vast_bedrag_op_vestiging  (BASVO005.03)  ← listed first = Operaton primary key
    Sub-decision: vestiging_voldoet_aan_minimum_leerlingen (BASVO005.04 / 005.09)

    Input data nodes and their wiring
    ──────────────────────────────────
    id_aantalLeerl   aantalLeerlingenVastBedrag             Integer  → sub-decision
    id_minimumAant   minimumAantalLeerlingen                Integer  → sub-decision
    id_tijdelijk     vestigingIsTijdelijk                   Boolean  → primary decision
    id_verticaal     vestigingIsVerticaleScholengemeenschap Boolean  → primary decision
    id_hoofd         vestigingIsHoofdvestiging              Boolean  → primary decision

    TODO BASVO002.03: replace 93765.0 with the official 2025 hoofdvestiging amount
    once confirmed from the Staatscourant.
  -->

  <!-- ═══════════════════════════════════════════════════════════
       PRIMARY decision: BASVO005.03  (listed first = Operaton primary key)
       Vast bedrag van toepassing op vestiging
       ═══════════════════════════════════════════════════════════ -->
  <decision id="vast_bedrag_op_vestiging"
            name="Vast bedrag van toepassing op vestiging (BASVO005.03)"
            camunda:historyTimeToLive="10">

    <!-- Required sub-decision -->
    <informationRequirement id="ir_subDecision">
      <requiredDecision href="#vestiging_voldoet_aan_minimum_leerlingen"/>
    </informationRequirement>

    <!-- Required input data -->
    <informationRequirement id="ir_tijdelijk">
      <requiredInput href="#id_tijdelijk"/>
    </informationRequirement>
    <informationRequirement id="ir_verticaal">
      <requiredInput href="#id_verticaal"/>
    </informationRequirement>
    <informationRequirement id="ir_hoofd">
      <requiredInput href="#id_hoofd"/>
    </informationRequirement>

    <decisionTable id="dt_vastBedrag" hitPolicy="FIRST">

      <input id="in_tijdelijk" label="vestiging is tijdelijk">
        <inputExpression id="ie_tijdelijk" typeRef="boolean">
          <text>vestigingIsTijdelijk</text>
        </inputExpression>
      </input>
      <input id="in_voldoetMin" label="vestiging voldoet aan eis minimum aantal leerlingen">
        <inputExpression id="ie_voldoetMin" typeRef="boolean">
          <text>vestigingVoldoetAanMinimumLeerlingen</text>
        </inputExpression>
      </input>
      <input id="in_verticaal" label="vestiging is onderdeel van verticale scholengemeenschap">
        <inputExpression id="ie_verticaal" typeRef="boolean">
          <text>vestigingIsVerticaleScholengemeenschap</text>
        </inputExpression>
      </input>
      <input id="in_hoofd" label="vestiging is hoofdvestiging">
        <inputExpression id="ie_hoofd" typeRef="boolean">
          <text>vestigingIsHoofdvestiging</text>
        </inputExpression>
      </input>

      <output id="out_vastBedrag"
              label="vast bedrag basisbekostiging (euro)"
              name="vastBedrag"
              typeRef="double"/>
      <output id="out_toelichting"
              label="toelichting"
              name="vastBedragToelichting"
              typeRef="string"/>

      <!-- Row 1: tijdelijke vestiging → geen vast bedrag (BASVO005.03 row 1) -->
      <rule id="rule_vb_1">
        <description>Tijdelijke vestiging komt niet in aanmerking voor vast bedrag</description>
        <inputEntry id="ie_vb_1a"><text>true</text></inputEntry>
        <inputEntry id="ie_vb_1b"><text></text></inputEntry>
        <inputEntry id="ie_vb_1c"><text></text></inputEntry>
        <inputEntry id="ie_vb_1d"><text></text></inputEntry>
        <outputEntry id="oe_vb_1a"><text>0.0</text></outputEntry>
        <outputEntry id="oe_vb_1b"><text>"Geen vast bedrag: vestiging is tijdelijk"</text></outputEntry>
      </rule>

      <!-- Row 2: te weinig leerlingen → geen vast bedrag (BASVO005.03 row 2) -->
      <rule id="rule_vb_2">
        <description>Vestiging voldoet niet aan minimumeis leerlingen</description>
        <inputEntry id="ie_vb_2a"><text>false</text></inputEntry>
        <inputEntry id="ie_vb_2b"><text>false</text></inputEntry>
        <inputEntry id="ie_vb_2c"><text></text></inputEntry>
        <inputEntry id="ie_vb_2d"><text></text></inputEntry>
        <outputEntry id="oe_vb_2a"><text>0.0</text></outputEntry>
        <outputEntry id="oe_vb_2b"><text>"Geen vast bedrag: vestiging voldoet niet aan minimumeis leerlingen"</text></outputEntry>
      </rule>

      <!-- Row 3: geen verticale scholengemeenschap, hoofdvestiging (BASVO005.03 row 3) -->
      <rule id="rule_vb_3">
        <description>Geen verticale scholengemeenschap, hoofdvestiging</description>
        <inputEntry id="ie_vb_3a"><text>false</text></inputEntry>
        <inputEntry id="ie_vb_3b"><text>true</text></inputEntry>
        <inputEntry id="ie_vb_3c"><text>false</text></inputEntry>
        <inputEntry id="ie_vb_3d"><text>true</text></inputEntry>
        <outputEntry id="oe_vb_3a"><text>93765.0</text></outputEntry>
        <outputEntry id="oe_vb_3b"><text>"Vast bedrag hoofdvestiging 2025 (BASVO002.03) — TODO: vervang 93765.0 door officieel bedrag uit Staatscourant"</text></outputEntry>
      </rule>

      <!-- Row 4: geen verticale scholengemeenschap, nevenvestiging (BASVO005.03 row 4) -->
      <rule id="rule_vb_4">
        <description>Geen verticale scholengemeenschap, nevenvestiging</description>
        <inputEntry id="ie_vb_4a"><text>false</text></inputEntry>
        <inputEntry id="ie_vb_4b"><text>true</text></inputEntry>
        <inputEntry id="ie_vb_4c"><text>false</text></inputEntry>
        <inputEntry id="ie_vb_4d"><text>false</text></inputEntry>
        <outputEntry id="oe_vb_4a"><text>13779.0</text></outputEntry>
        <outputEntry id="oe_vb_4b"><text>"Vast bedrag nevenvestiging 2025 (BASVO002.04): 13779 euro"</text></outputEntry>
      </rule>

      <!-- Row 5: verticale scholengemeenschap, hoofdvestiging (BASVO005.03 row 5) -->
      <rule id="rule_vb_5">
        <description>Verticale scholengemeenschap, hoofdvestiging</description>
        <inputEntry id="ie_vb_5a"><text>false</text></inputEntry>
        <inputEntry id="ie_vb_5b"><text>true</text></inputEntry>
        <inputEntry id="ie_vb_5c"><text>true</text></inputEntry>
        <inputEntry id="ie_vb_5d"><text>true</text></inputEntry>
        <outputEntry id="oe_vb_5a"><text>93765.0</text></outputEntry>
        <outputEntry id="oe_vb_5b"><text>"Vast bedrag hoofdvestiging 2025 – verticale scholengemeenschap (BASVO002.03) — TODO: vervang 93765.0 door officieel bedrag"</text></outputEntry>
      </rule>

      <!-- Row 6: verticale scholengemeenschap, nevenvestiging (BASVO005.03 row 6) -->
      <rule id="rule_vb_6">
        <description>Verticale scholengemeenschap, nevenvestiging</description>
        <inputEntry id="ie_vb_6a"><text>false</text></inputEntry>
        <inputEntry id="ie_vb_6b"><text>true</text></inputEntry>
        <inputEntry id="ie_vb_6c"><text>true</text></inputEntry>
        <inputEntry id="ie_vb_6d"><text>false</text></inputEntry>
        <outputEntry id="oe_vb_6a"><text>13779.0</text></outputEntry>
        <outputEntry id="oe_vb_6b"><text>"Vast bedrag nevenvestiging 2025 – verticale scholengemeenschap (BASVO002.04): 13779 euro"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- ═══════════════════════════════════════════════════════════
       Sub-decision: BASVO005.04 / 005.09
       Vestiging voldoet aan minimumeis leerlingen
       ═══════════════════════════════════════════════════════════ -->
  <decision id="vestiging_voldoet_aan_minimum_leerlingen"
            name="Vestiging voldoet aan minimumeis leerlingen (BASVO005.04)"
            camunda:historyTimeToLive="10">

    <!-- Required input data -->
    <informationRequirement id="ir_aantalLeerl">
      <requiredInput href="#id_aantalLeerl"/>
    </informationRequirement>
    <informationRequirement id="ir_minimumAant">
      <requiredInput href="#id_minimumAant"/>
    </informationRequirement>

    <decisionTable id="dt_minimumLeerlingen" hitPolicy="FIRST">

      <input id="in_aantalLeerlingen" label="aantal leerlingen vast bedrag basisbekostiging">
        <inputExpression id="ie_aantalLeerlingen" typeRef="integer">
          <text>aantalLeerlingenVastBedrag</text>
        </inputExpression>
      </input>
      <input id="in_minimumAantal" label="minimum aantal leerlingen (Uitvoeringsbesluit WVO 2020)">
        <inputExpression id="ie_minimumAantal" typeRef="integer">
          <text>minimumAantalLeerlingen</text>
        </inputExpression>
      </input>

      <output id="out_voldoetMinimum"
              label="vestiging voldoet aan minimum aantal leerlingen"
              name="vestigingVoldoetAanMinimumLeerlingen"
              typeRef="boolean"/>

      <!-- Row 1: voldoende leerlingen (BASVO005.09) -->
      <rule id="rule_min_1">
        <description>Aantal leerlingen bereikt of overstijgt minimum (BASVO005.09)</description>
        <inputEntry id="ie_min_1a"><text>&gt;= minimumAantalLeerlingen</text></inputEntry>
        <inputEntry id="ie_min_1b"><text></text></inputEntry>
        <outputEntry id="oe_min_1"><text>true</text></outputEntry>
      </rule>

      <!-- Row 2: onvoldoende leerlingen -->
      <rule id="rule_min_2">
        <description>Aantal leerlingen ligt onder minimum</description>
        <inputEntry id="ie_min_2a"><text>&lt; minimumAantalLeerlingen</text></inputEntry>
        <inputEntry id="ie_min_2b"><text></text></inputEntry>
        <outputEntry id="oe_min_2"><text>false</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <!-- ═══════════════════════════════════════════════════════════
       Input data nodes
       ═══════════════════════════════════════════════════════════ -->
  <inputData id="id_tijdelijk"   name="vestigingIsTijdelijk"/>
  <inputData id="id_verticaal"   name="vestigingIsVerticaleScholengemeenschap"/>
  <inputData id="id_hoofd"       name="vestigingIsHoofdvestiging"/>
  <inputData id="id_aantalLeerl" name="aantalLeerlingenVastBedrag"/>
  <inputData id="id_minimumAant" name="minimumAantalLeerlingen"/>

  <!-- ═══════════════════════════════════════════════════════════
       DMNDI layout
       ═══════════════════════════════════════════════════════════ -->
  <dmndi:DMNDI>
    <dmndi:DMNDiagram>

      <!-- Primary decision -->
      <dmndi:DMNShape dmnElementRef="vast_bedrag_op_vestiging">
        <dc:Bounds x="200" y="280" width="300" height="80"/>
      </dmndi:DMNShape>

      <!-- Sub-decision -->
      <dmndi:DMNShape dmnElementRef="vestiging_voldoet_aan_minimum_leerlingen">
        <dc:Bounds x="200" y="100" width="300" height="80"/>
      </dmndi:DMNShape>

      <!-- Input data nodes wired to sub-decision -->
      <dmndi:DMNShape dmnElementRef="id_aantalLeerl">
        <dc:Bounds x="560" y="100" width="180" height="45"/>
      </dmndi:DMNShape>
      <dmndi:DMNShape dmnElementRef="id_minimumAant">
        <dc:Bounds x="560" y="155" width="180" height="45"/>
      </dmndi:DMNShape>

      <!-- Input data nodes wired to primary decision -->
      <dmndi:DMNShape dmnElementRef="id_tijdelijk">
        <dc:Bounds x="560" y="260" width="180" height="45"/>
      </dmndi:DMNShape>
      <dmndi:DMNShape dmnElementRef="id_verticaal">
        <dc:Bounds x="560" y="315" width="180" height="45"/>
      </dmndi:DMNShape>
      <dmndi:DMNShape dmnElementRef="id_hoofd">
        <dc:Bounds x="560" y="370" width="180" height="45"/>
      </dmndi:DMNShape>

      <!-- Edge: sub-decision → primary decision -->
      <dmndi:DMNEdge dmnElementRef="ir_subDecision">
        <di:waypoint x="350" y="180"/>
        <di:waypoint x="350" y="280"/>
      </dmndi:DMNEdge>

      <!-- Edges: inputData → sub-decision -->
      <dmndi:DMNEdge dmnElementRef="ir_aantalLeerl">
        <di:waypoint x="560" y="122"/>
        <di:waypoint x="500" y="140"/>
      </dmndi:DMNEdge>
      <dmndi:DMNEdge dmnElementRef="ir_minimumAant">
        <di:waypoint x="560" y="177"/>
        <di:waypoint x="500" y="160"/>
      </dmndi:DMNEdge>

      <!-- Edges: inputData → primary decision -->
      <dmndi:DMNEdge dmnElementRef="ir_tijdelijk">
        <di:waypoint x="560" y="282"/>
        <di:waypoint x="500" y="310"/>
      </dmndi:DMNEdge>
      <dmndi:DMNEdge dmnElementRef="ir_verticaal">
        <di:waypoint x="560" y="337"/>
        <di:waypoint x="500" y="330"/>
      </dmndi:DMNEdge>
      <dmndi:DMNEdge dmnElementRef="ir_hoofd">
        <di:waypoint x="560" y="392"/>
        <di:waypoint x="500" y="350"/>
      </dmndi:DMNEdge>

    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
