# ============================================================
#  DMN Decision Model
# ============================================================

<https://regels.overheid.nl/services/rip-assignment/dmn> a cprmv:DecisionModel ;
    dct:identifier "RipProjectTypeAssignment" ;
    dct:title "RipProjectTypeAssignment.dmn"@nl ;
    cprmv:implements <https://regels.overheid.nl/services/rip-assignment> ;
    dct:source <https://regels.overheid.nl/services/rip-assignment/dmn/file> ;
    cprmv:deploymentId "b2edb370-1ef1-11f1-8761-8ae6f7653f6b" ;
    cprmv:deployedAt "2026-03-13T15:31:26.358Z"^^xsd:dateTime ;
    cprmv:implementedBy <https://operaton.open-regels.nl/engine-rest/decision-definition/key/RipProjectTypeAssignment/evaluate> ;
    cprmv:lastTested "2026-03-13T15:32:11.675Z"^^xsd:dateTime ;
    cprmv:testStatus "passed" ;
    dct:description "DMN decision model for service evaluation"@nl .

<https://regels.overheid.nl/services/rip-assignment/dmn/input/1> a cpsv:Input ;
    dct:identifier "projectType" ;
    dct:title "projectType"@nl ;
    dct:type "String" ;
    schema:value "" ;
    cpsv:isRequiredBy <https://regels.overheid.nl/services/rip-assignment/dmn> .

<https://regels.overheid.nl/services/rip-assignment/dmn/input/2> a cpsv:Input ;
    dct:identifier "department" ;
    dct:title "department"@nl ;
    dct:type "String" ;
    schema:value "infrastructuur" ;
    cpsv:isRequiredBy <https://regels.overheid.nl/services/rip-assignment/dmn> .

<https://regels.overheid.nl/services/rip-assignment/dmn/output/1> a cpsv:Output ;
    dct:identifier "assignedRoles" ;
    dct:title "assignedRoles"@nl ;
    dct:type "String" ;
    schema:value "infra-medewerker" ;
    cpsv:produces <https://regels.overheid.nl/services/rip-assignment/dmn> .

<https://regels.overheid.nl/services/rip-assignment/dmn/output/2> a cpsv:Output ;
    dct:identifier "candidateGroups" ;
    dct:title "candidateGroups"@nl ;
    dct:type "String" ;
    schema:value "infra-projectteam" ;
    cpsv:produces <https://regels.overheid.nl/services/rip-assignment/dmn> .

<https://regels.overheid.nl/services/rip-assignment/rules/Rule_01> a cpsv:Rule, cprmv:DecisionRule ;
    dct:identifier "Rule_01" ;
    cpsv:implements <https://regels.overheid.nl/services/rip-assignment> ;
    cprmv:ruleType "decision-rule" ;
    cprmv:confidence "medium" ;
    cprmv:decisionTable "DecisionTable_RipProjectTypeAssignment" ;
    cprmv:rulesetType "decision-table" .

