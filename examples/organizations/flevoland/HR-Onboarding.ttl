# ============================================================
#  DMN Decision Model
# ============================================================

<https://regels.overheid.nl/services/hr-onboarding/dmn> a cprmv:DecisionModel ;
    dct:identifier "EmployeeRoleAssignment" ;
    dct:title "EmployeeRoleAssignment.dmn"@nl ;
    cprmv:implements <https://regels.overheid.nl/services/hr-onboarding> ;
    dct:source <https://regels.overheid.nl/services/hr-onboarding/dmn/file> ;
    cprmv:deploymentId "bbb8dba0-1eee-11f1-8761-8ae6f7653f6b" ;
    cprmv:deployedAt "2026-03-13T15:10:12.627Z"^^xsd:dateTime ;
    cprmv:implementedBy <https://operaton.open-regels.nl/engine-rest/decision-definition/key/EmployeeRoleAssignment/evaluate> ;
    cprmv:lastTested "2026-03-13T15:12:35.105Z"^^xsd:dateTime ;
    cprmv:testStatus "passed" ;
    dct:description "DMN decision model for service evaluation"@nl .

<https://regels.overheid.nl/services/hr-onboarding/dmn/input/1> a cpsv:Input ;
    dct:identifier "department" ;
    dct:title "department"@nl ;
    dct:type "String" ;
    schema:value "infrastructuur" ;
    cpsv:isRequiredBy <https://regels.overheid.nl/services/hr-onboarding/dmn> .

<https://regels.overheid.nl/services/hr-onboarding/dmn/input/2> a cpsv:Input ;
    dct:identifier "jobFunction" ;
    dct:title "jobFunction"@nl ;
    dct:type "String" ;
    schema:value "projectleider" ;
    cpsv:isRequiredBy <https://regels.overheid.nl/services/hr-onboarding/dmn> .

<https://regels.overheid.nl/services/hr-onboarding/dmn/output/1> a cpsv:Output ;
    dct:identifier "accessLevel" ;
    dct:title "accessLevel"@nl ;
    dct:type "String" ;
    schema:value "admin" ;
    cpsv:produces <https://regels.overheid.nl/services/hr-onboarding/dmn> .

<https://regels.overheid.nl/services/hr-onboarding/dmn/output/2> a cpsv:Output ;
    dct:identifier "assignedRoles" ;
    dct:title "assignedRoles"@nl ;
    dct:type "String" ;
    schema:value "caseworker,rip-verkenner,rip-planner,rip-contractbeheer" ;
    cpsv:produces <https://regels.overheid.nl/services/hr-onboarding/dmn> .

<https://regels.overheid.nl/services/hr-onboarding/dmn/output/3> a cpsv:Output ;
    dct:identifier "candidateGroups" ;
    dct:title "candidateGroups"@nl ;
    dct:type "String" ;
    schema:value "caseworker,rip-projectleider" ;
    cpsv:produces <https://regels.overheid.nl/services/hr-onboarding/dmn> .

<https://regels.overheid.nl/services/hr-onboarding/rules/Rule_01> a cpsv:Rule, cprmv:DecisionRule ;
