# =====================================
# NL-SBB Concept Definitions (DMN Variables)
# =====================================

<https://regels.overheid.nl/schemes/dmn-variables> a skos:ConceptScheme ;
    dct:title "DMN Variabelen Begrippenkader"@nl ;
    dct:description "Begrippenkader voor invoer- en uitvoervariabelen van DMN beslisregels in het RONL stelsel."@nl ;
    dct:creator "RONL" ;
    dct:created "2026-03-13"^^xsd:date .

# Input Variable Concepts

<https://regels.overheid.nl/concepts/employeeroleassignment/department> a skos:Concept ;
    skos:prefLabel "Department"@nl ;
    skos:definition "Department is een tekstuele waarde die als invoer dient voor de beslisregel."@nl ;
    skos:notation "DEPA" ;
    dct:subject <https://regels.overheid.nl/services/hr-onboarding/dmn/input/1> ;
    dct:type "dmn:InputVariable" ;
    skos:exactMatch <https://regels.overheid.nl/concepts/department> ;
    skos:inScheme <https://regels.overheid.nl/schemes/dmn-variables> .

<https://regels.overheid.nl/concepts/employeeroleassignment/jobFunction> a skos:Concept ;
    skos:prefLabel "Job Function"@nl ;
    skos:definition "Job Function is een tekstuele waarde die als invoer dient voor de beslisregel."@nl ;
    skos:notation "JF" ;
    dct:subject <https://regels.overheid.nl/services/hr-onboarding/dmn/input/2> ;
    dct:type "dmn:InputVariable" ;
    skos:exactMatch <https://regels.overheid.nl/concepts/jobFunction> ;
    skos:inScheme <https://regels.overheid.nl/schemes/dmn-variables> .

# Output Variable Concepts

<https://regels.overheid.nl/concepts/employeeroleassignment/accessLevel> a skos:Concept ;
    skos:prefLabel "Access Level"@nl ;
    skos:definition "Access Level is een tekstuele waarde die als uitvoer wordt gegenereerd door de beslisregel."@nl ;
    skos:notation "AL" ;
    dct:subject <https://regels.overheid.nl/services/hr-onboarding/dmn/output/1> ;
    dct:type "dmn:OutputVariable" ;
    skos:exactMatch <https://regels.overheid.nl/concepts/accessLevel> ;
    skos:inScheme <https://regels.overheid.nl/schemes/dmn-variables> .

<https://regels.overheid.nl/concepts/employeeroleassignment/assignedRoles> a skos:Concept ;
    skos:prefLabel "Assigned Roles"@nl ;
    skos:definition "Assigned Roles is een tekstuele waarde die als uitvoer wordt gegenereerd door de beslisregel."@nl ;
    skos:notation "AR" ;
    dct:subject <https://regels.overheid.nl/services/hr-onboarding/dmn/output/2> ;
    dct:type "dmn:OutputVariable" ;
    skos:exactMatch <https://regels.overheid.nl/concepts/assignedRoles> ;
    skos:inScheme <https://regels.overheid.nl/schemes/dmn-variables> .

<https://regels.overheid.nl/concepts/employeeroleassignment/candidateGroups> a skos:Concept ;
    skos:prefLabel "Candidate Groups"@nl ;
    skos:definition "Candidate Groups is een tekstuele waarde die als uitvoer wordt gegenereerd door de beslisregel."@nl ;
    skos:notation "CG" ;
    dct:subject <https://regels.overheid.nl/services/hr-onboarding/dmn/output/3> ;
    dct:type "dmn:OutputVariable" ;
    skos:exactMatch <https://regels.overheid.nl/concepts/candidateGroups> ;
    skos:inScheme <https://regels.overheid.nl/schemes/dmn-variables> .

